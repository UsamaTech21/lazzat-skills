# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo

# Secrets / credentials (never commit)
.env
.env.*
*.pem
*.key
*_credentials.*
credentials.json
secrets.json
/.secrets/

# Build output / logs
*.log
node_modules/
dist/
build/
out/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Temporary extraction / working files (used when ingesting raw Lazzat docs)
/_extracted/
/_guidelines.txt
/_addendum.txt
/_extract.py
/LazzatData/

# Local validator outputs
validate-*.out
.skill-cache/

# AI tooling local state
.claude/
.cursor/
.agents/local/

# Don't commit binary source material — keep only extracted markdown
*.docx
*.xlsx
*.pdf
!references/**/*.pdf
!references/**/*.xlsx
